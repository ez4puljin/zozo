# Database - SQLite local file (libSQL-compatible).
# For production on Vercel, point this at a Turso DB or Neon Postgres
# (swap drizzle config too — see drizzle.config.ts).
DATABASE_URL=file:./data/zozo.db
# DATABASE_AUTH_TOKEN=                   # required for Turso

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=ZoZo

# Admin auth
# Generate hash: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'yourpassword'
ADMIN_PASSWORD_HASH=$2a$12$REPLACEME
# Generate secret: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET=REPLACEME

# Email (Resend) - admin notifications
RESEND_API_KEY=re_REPLACEME
RESEND_FROM_EMAIL=onboarding@resend.dev
ADMIN_NOTIFICATION_EMAIL=owner@example.com

# Vercel Blob - product images (production only; in dev images are tracked URLs)
BLOB_READ_WRITE_TOKEN=

# Facebook Pixel - optional, leave blank in dev
NEXT_PUBLIC_FB_PIXEL_ID=

# Telegram order notifications (free, reliable; recommended).
# Get a token from @BotFather, then run scripts/telegram-setup.ts for the chat id.
# TELEGRAM_CHAT_ID can be one id or a comma-separated list.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
